{
  "name": "portfoliotrack",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "node --import tsx --test \"tests/**/*.test.ts\"",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "typecheck": "tsc --noEmit --pretty false",
    "verify": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build",
    "verify:full": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run test:e2e && pnpm run build",
    "lint": "eslint .",
    "format": "prettier --write . --ignore-unknown",
    "format:check": "prettier --check . --ignore-unknown",
    "config:check": "node scripts/check-env.mjs",
    "config:check:prod": "node scripts/check-env.mjs --mode production",
    "db:local:up": "echo Use the machine-level PostgreSQL service from pgAdmin on localhost:5432, then run pnpm run db:migrate.",
    "db:local:down": "echo Stop the machine-level PostgreSQL service from Windows Services if you need to stop local Postgres.",
    "db:generate": "drizzle-kit generate",
    "db:check": "drizzle-kit check",
    "db:migrate": "pnpm run db:migrate:local",
    "db:migrate:local": "drizzle-kit push",
    "db:migrate:prod": "pnpm run config:check:prod && drizzle-kit migrate",
    "db:seed": "tsx src/lib/db/seed.ts",
    "auth:hash": "node scripts/generate-admin-password-hash.mjs"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@vercel/functions": "^3.6.1",
    "drizzle-orm": "^0.45.2",
    "exceljs": "^4.4.0",
    "next": "^16.2.6",
    "pg": "^8.21.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.1",
    "yahoo-finance2": "^3.14.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "playwright": "^1.60.0",
    "postcss": "^8.4.49",
    "prettier": "^3.8.3",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3"
  }
}
