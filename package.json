{
  "name": "portfoliotrack",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "node --import tsx --test \"tests/**/*.test.ts\"",
    "verify": "npm run lint && npm run test && npm run build",
    "lint": "eslint .",
    "db:local:up": "echo Use the machine-level PostgreSQL service from pgAdmin on localhost:5432, then run npm run db:migrate.",
    "db:local:down": "echo Stop the machine-level PostgreSQL service from Windows Services if you need to stop local Postgres.",
    "db:migrate": "drizzle-kit push",
    "db:seed": "tsx src/lib/db/seed.ts",
    "auth:hash": "node scripts/generate-admin-password-hash.mjs"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "drizzle-orm": "^0.45.2",
    "exceljs": "^4.4.0",
    "next": "^15.0.0",
    "pg": "^8.21.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.12.7",
    "yahoo-finance2": "^3.14.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.1.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.4.49",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
